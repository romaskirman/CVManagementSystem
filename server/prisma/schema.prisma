generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleCode {
  CANDIDATE
  RECRUITER
  ADMIN
}

enum Theme {
  LIGHT
  DARK
}

enum Language {
  EN
  RU
}

enum AttributeCategory {
  PERSONAL_INFORMATION
  CERTIFICATION
  DOMAIN_KNOWLEDGE
  SOFT_SKILLS
  HARD_SKILLS
  EDUCATION
  LANGUAGE
  EXPERIENCE
  OTHER
}

enum AttributeType {
  STRING
  TEXT
  IMAGE
  NUMERIC
  DATE
  PERIOD
  BOOLEAN
  ONE_OF_MANY
}

enum PositionVisibilityMode {
  PUBLIC
  RESTRICTED
}

enum PositionLevel {
  JUNIOR
  MIDDLE
  SENIOR
  C_LEVEL
}

enum RuleOperator {
  EQUALS
  NOT_EQUALS
  CONTAINS
  STARTS_WITH
  GREATER_THAN
  GREATER_THAN_OR_EQUAL
  LESS_THAN
  LESS_THAN_OR_EQUAL
  IS_TRUE
  IS_FALSE
  BEFORE
  AFTER
  ON
  OVERLAPS
  IN_SET
}

enum CvStatus {
  DRAFT
  PUBLISHED
}

enum AuthProvider {
  LOCAL
  GOOGLE
  FACEBOOK
}

model User {
  id                    String                   @id @default(cuid())
  email                 String                   @unique
  passwordHash          String?
  isBlocked             Boolean                  @default(false)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  roles                 UserRole[]
  oauthAccounts         OAuthAccount[]
  preference            UserPreference?
  candidateProfile      CandidateProfile?
  createdAttributes     AttributeDefinition[]    @relation("AttributeCreatedBy")
  createdPositions      Position[]               @relation("PositionCreatedBy")
  updatedPositions      Position[]               @relation("PositionUpdatedBy")
  discussionPosts       PositionDiscussionPost[]
  cvLikes               CvLike[]
  recentAttributeUsages RecentAttributeUsage[]
}

model Role {
  id        String   @id @default(cuid())
  code      RoleCode @unique
  createdAt DateTime @default(now())

  userRoles UserRole[]
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model OAuthAccount {
  id             String       @id @default(cuid())
  userId         String
  provider       AuthProvider
  providerUserId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model UserPreference {
  userId    String   @id
  theme     Theme    @default(LIGHT)
  language  Language @default(EN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSession {
  sid    String   @id
  sess   Json
  expire DateTime

  @@map("user_sessions")
  @@index([expire])
}

model CandidateProfile {
  id              String                  @id @default(cuid())
  userId          String                  @unique
  version         Int                     @default(1)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  attributeValues ProfileAttributeValue[]
  projects        Project[]
  cvs             Cv[]
}

model AttributeDefinition {
  id                 String                 @id @default(cuid())
  category           AttributeCategory
  name               String                 @unique
  description        String
  type               AttributeType
  isBuiltIn          Boolean                @default(false)
  isDeletable        Boolean                @default(true)
  createdById        String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  createdBy          User?                  @relation("AttributeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  options            AttributeOption[]
  profileValues      ProfileAttributeValue[]
  positionAttributes PositionAttribute[]
  accessRules        PositionAccessRule[]
  recentUsages       RecentAttributeUsage[]

  @@index([category])
  @@index([type])
  @@index([name])
}

model AttributeOption {
  id            String                  @id @default(cuid())
  attributeId   String
  label         String
  sortOrder     Int                     @default(0)
  createdAt     DateTime                @default(now())

  attribute     AttributeDefinition     @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  profileValues ProfileAttributeValue[]
  accessRules   PositionAccessRule[]

  @@unique([attributeId, label])
  @@index([attributeId, sortOrder])
}

model RecentAttributeUsage {
  userId      String
  attributeId String
  lastUsedAt  DateTime @default(now())

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  attribute   AttributeDefinition @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([userId, attributeId])
  @@index([lastUsedAt])
}

model ProfileAttributeValue {
  id           String               @id @default(cuid())
  profileId    String
  attributeId  String
  version      Int                  @default(1)
  stringValue  String?
  textValue    String?
  numberValue  Decimal?             @db.Decimal(12, 2)
  booleanValue Boolean?
  dateValue    DateTime?
  periodStart  DateTime?
  periodEnd    DateTime?
  imageUrl     String?
  optionId     String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  profile      CandidateProfile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  attribute    AttributeDefinition  @relation(fields: [attributeId], references: [id], onDelete: Restrict)
  option       AttributeOption?     @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@unique([profileId, attributeId])
  @@index([attributeId])
  @@index([optionId])
}

model Project {
  id                  String                 @id @default(cuid())
  profileId           String
  name                String
  periodStart         DateTime?
  periodEnd           DateTime?
  descriptionMarkdown String
  version             Int                    @default(1)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  profile             CandidateProfile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  tagLinks            ProjectTechnologyTag[]
  cvProjects          CvProject[]

  @@index([profileId, updatedAt])
  @@index([name])
}

model TechnologyTag {
  id            String               @id @default(cuid())
  name          String               @unique
  createdAt     DateTime             @default(now())

  projectLinks  ProjectTechnologyTag[]
  positionLinks PositionProjectTag[]

  @@index([name])
}

model ProjectTechnologyTag {
  projectId String
  tagId     String

  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag       TechnologyTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([projectId, tagId])
  @@index([tagId])
}

model Position {
  id               String                  @id @default(cuid())
  title            String
  shortDescription String
  visibilityMode   PositionVisibilityMode  @default(PUBLIC)
  company          String?
  level            PositionLevel?
  maxProjects      Int                     @default(3)
  version          Int                     @default(1)
  createdById      String?
  updatedById      String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  createdBy        User?                   @relation("PositionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy        User?                   @relation("PositionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  attributes       PositionAttribute[]
  accessRules      PositionAccessRule[]
  projectTags      PositionProjectTag[]
  cvs              Cv[]
  discussionPosts  PositionDiscussionPost[]

  @@index([updatedAt])
  @@index([createdAt])
  @@index([title])
  @@index([company])
  @@index([level])
}

model PositionAttribute {
  id          String              @id @default(cuid())
  positionId  String
  attributeId String
  sortOrder   Int                 @default(0)
  isRequired  Boolean             @default(true)
  createdAt   DateTime            @default(now())

  position    Position            @relation(fields: [positionId], references: [id], onDelete: Cascade)
  attribute   AttributeDefinition @relation(fields: [attributeId], references: [id], onDelete: Restrict)

  @@unique([positionId, attributeId])
  @@index([positionId, sortOrder])
  @@index([attributeId])
}

model PositionAccessRule {
  id              String              @id @default(cuid())
  positionId      String
  attributeId     String
  operator        RuleOperator
  stringValue     String?
  numberValue     Decimal?            @db.Decimal(12, 2)
  booleanValue    Boolean?
  dateValue       DateTime?
  secondDateValue DateTime?
  optionId        String?
  sortOrder       Int                 @default(0)
  createdAt       DateTime            @default(now())

  position        Position            @relation(fields: [positionId], references: [id], onDelete: Cascade)
  attribute       AttributeDefinition @relation(fields: [attributeId], references: [id], onDelete: Restrict)
  option          AttributeOption?    @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@index([positionId, sortOrder])
  @@index([attributeId])
  @@index([optionId])
}

model PositionProjectTag {
  positionId String
  tagId      String

  position   Position      @relation(fields: [positionId], references: [id], onDelete: Cascade)
  tag        TechnologyTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([positionId, tagId])
  @@index([tagId])
}

model Cv {
  id                 String      @id @default(cuid())
  candidateProfileId String
  positionId         String
  status             CvStatus    @default(DRAFT)
  version            Int         @default(1)
  publishedAt        DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  position           Position         @relation(fields: [positionId], references: [id], onDelete: Cascade)
  likes              CvLike[]
  selectedProjects   CvProject[]

  @@unique([candidateProfileId, positionId])
  @@index([positionId, status])
  @@index([candidateProfileId, updatedAt])
  @@index([publishedAt])
}

model CvProject {
  cvId      String
  projectId String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  cv        Cv      @relation(fields: [cvId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([cvId, projectId])
  @@index([projectId])
  @@unique([cvId, sortOrder])
}

model CvLike {
  cvId            String
  recruiterUserId String
  createdAt       DateTime @default(now())

  cv              Cv   @relation(fields: [cvId], references: [id], onDelete: Cascade)
  recruiter       User @relation(fields: [recruiterUserId], references: [id], onDelete: Cascade)

  @@id([cvId, recruiterUserId])
  @@index([recruiterUserId])
}

model PositionDiscussionPost {
  id           String   @id @default(cuid())
  positionId   String
  authorUserId String
  bodyMarkdown String
  createdAt    DateTime @default(now())

  position     Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  author       User     @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([positionId, createdAt])
  @@index([authorUserId])
}
