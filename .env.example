# Shared project notes:
# Copy relevant values into client/.env and server/.env

NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cv_management_system?schema=public

# Server
SERVER_PORT=4000
SERVER_URL=http://localhost:4000
CLIENT_URL=http://localhost:5173
SESSION_SECRET=change-me-super-secret

# OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret

# Optional local auth seed admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin12345!

# External image hosting / cloud storage
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
